# =============================================
# BakBak Chat - Backend Environment Variables
# =============================================
# INSTRUCTIONS: Fill in YOUR actual values below.
# NEVER commit this file to Git.

# ----- SERVER -----
PORT=5000
NODE_ENV=development

# ----- MONGODB ATLAS -----
# Get this from: MongoDB Atlas > Your Cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bakbak?retryWrites=true&w=majority

# ----- JWT SECRET -----
# Use a long random string (min 32 chars). 
# Generate one: https://generate-secret.vercel.app/32
JWT_SECRET=REPLACE_WITH_YOUR_SUPER_SECRET_KEY_MIN_32_CHARACTERS
JWT_EXPIRE=7d

# ----- FRONTEND URL (for CORS) -----
CLIENT_URL=http://localhost:5173

# ----- CLOUDINARY (for profile pictures & media) -----
# Get from: https://cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
